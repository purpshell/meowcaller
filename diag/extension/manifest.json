{
  "manifest_version": 3,
  "name": "meowcaller WhatsApp VoIP diagnostics",
  "version": "4.1.0",
  "description": "Headless WhatsApp Web VoIP research capture",
  "permissions": ["tabs", "debugger"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/bg.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["src/content-script.js"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": [
      "src/wam.js",
      "src/voip-capture-core.js",
      "src/voip-browser-hooks.js",
      "src/main.js",
      "src/voip-capture.js"
    ],
    "matches": ["https://web.whatsapp.com/*"]
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
